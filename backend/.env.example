# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Neon (free tier): copie a connection string do dashboard Neon
# Formato: postgresql://usuario:senha@ep-xxx.region.aws.neon.tech/calctrabalho?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/calctrabalho

# Configurações individuais (alternativa ao DATABASE_URL — apenas para dev local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calctrabalho
DB_USER=calctrabalho
DB_PASSWORD=calctrabalho123

# Forçar SSL mesmo fora de NODE_ENV=production (útil para Neon em dev)
# DATABASE_SSL=true

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Em produção (Render), deixe vazio — o frontend é servido pelo backend
# Se usar domínio separado: FRONTEND_URL=https://seu-app.onrender.com
FRONTEND_URL=

# ─── Puppeteer ─────────────────────────────────────────────────────────────────
# Configurado automaticamente no Dockerfile (não precisa definir aqui)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ─── Claude AI ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
