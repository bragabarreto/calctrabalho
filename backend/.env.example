# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Railway fornece automaticamente DATABASE_URL ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/calctrabalho

# Configurações individuais (alternativa ao DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calctrabalho
DB_USER=calctrabalho
DB_PASSWORD=calctrabalho123

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Em produção (single service Railway), deixe vazio — o frontend é servido pelo backend
# Se usar Vercel/Netlify separado: FRONTEND_URL=https://seu-app.vercel.app
FRONTEND_URL=

# ─── Puppeteer ─────────────────────────────────────────────────────────────────
# Configurado automaticamente no Dockerfile
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
